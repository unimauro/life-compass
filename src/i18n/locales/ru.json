    "step2Desc": "\u0411\u0443\u0434\u044c\u0442\u0435 \u0440\u044f\u0434\u043e\u043c. \u041d\u0435 \u043f\u044b\u0442\u0430\u0439\u0442\u0435\u0441\u044c \u0438\u0441\u043f\u0440\u0430\u0432\u0438\u0442\u044c \u2014 \u043f\u0440\u043e\u0441\u0442\u043e \u0431\u0443\u0434\u044c\u0442\u0435 \u0440\u044f\u0434\u043e\u043c.",
    "step3Title": "\u041e\u0431\u0435\u0441\u043f\u0435\u0447\u044c\u0442\u0435 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u044c",
    "step3Desc": "\u0423\u0431\u0435\u0440\u0438\u0442\u0435 \u0434\u043e\u0441\u0442\u0443\u043f \u043a \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430\u043c. \u041e\u0441\u0442\u0430\u0432\u0430\u0439\u0442\u0435\u0441\u044c \u0440\u044f\u0434\u043e\u043c.",
    "step4Title": "\u041f\u043e\u043c\u043e\u0433\u0438\u0442\u0435 \u0441\u0432\u044f\u0437\u0430\u0442\u044c\u0441\u044f",
    "step4Desc": "\u041d\u0430\u043f\u0440\u0430\u0432\u044c\u0442\u0435 \u043a \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0441\u0442\u0430\u043c \u0438\u043b\u0438 \u043d\u0430 \u043a\u0440\u0438\u0437\u0438\u0441\u043d\u0443\u044e \u043b\u0438\u043d\u0438\u044e.",
    "step5Title": "\u041f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439\u0442\u0435 \u0441\u0432\u044f\u0437\u044c",
    "step5Desc": "\u0420\u0435\u0433\u0443\u043b\u044f\u0440\u043d\u043e \u0441\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0439\u0442\u0435 \u043a\u0430\u043a \u0434\u0435\u043b\u0430. \u0412\u0430\u0448\u0435 \u043f\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u0432\u0430\u0436\u043d\u043e.",
    "whatToSay": "\u0427\u0442\u043e \u043c\u043e\u0436\u043d\u043e \u0441\u043a\u0430\u0437\u0430\u0442\u044c",
    "whatNotToSay": "\u0427\u0442\u043e \u041d\u0415 \u0441\u0442\u043e\u0438\u0442 \u0433\u043e\u0432\u043e\u0440\u0438\u0442\u044c",
    "doSay1": "\"\u042f \u0440\u044f\u0434\u043e\u043c, \u0438 \u043c\u043d\u0435 \u043d\u0435 \u0432\u0441\u0451 \u0440\u0430\u0432\u043d\u043e.\"",
    "doSay2": "\"\u0422\u044b \u043d\u0435 \u043e\u0434\u0438\u043d.\"",
    "doSay3": "\"\u041f\u0440\u043e\u0441\u0438\u0442\u044c \u043e \u043f\u043e\u043c\u043e\u0449\u0438 \u2014 \u044d\u0442\u043e \u043d\u043e\u0440\u043c\u0430\u043b\u044c\u043d\u043e.\"",
    "doSay4": "\"\u0420\u0430\u0441\u0441\u043a\u0430\u0436\u0438, \u0447\u0442\u043e \u0442\u044b \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u0435\u0448\u044c.\"",
    "dontSay1Bad": "\"\u041f\u0440\u043e\u0441\u0442\u043e \u0434\u0443\u043c\u0430\u0439 \u043f\u043e\u0437\u0438\u0442\u0438\u0432\u043d\u043e.\"",
    "dontSay1Better": "\"\u042f \u0442\u0435\u0431\u044f \u0441\u043b\u044b\u0448\u0443. \u0422\u0432\u043e\u0438 \u0447\u0443\u0432\u0441\u0442\u0432\u0430 \u0432\u0430\u0436\u043d\u044b.\"",
    "dontSay2Bad": "\"\u0414\u0440\u0443\u0433\u0438\u043c \u0445\u0443\u0436\u0435.\"",
    "dontSay2Better": "\"\u0422\u0432\u043e\u044f \u0431\u043e\u043b\u044c \u0432\u0430\u0436\u043d\u0430 \u0432 \u043b\u044e\u0431\u043e\u043c \u0441\u043b\u0443\u0447\u0430\u0435.\"",
    "dontSay3Bad": "\"\u042d\u0442\u043e \u044d\u0433\u043e\u0438\u0437\u043c.\"",
    "dontSay3Better": "\"\u042f \u0432\u0438\u0436\u0443, \u0447\u0442\u043e \u0442\u0435\u0431\u0435 \u043e\u0447\u0435\u043d\u044c \u0431\u043e\u043b\u044c\u043d\u043e.\"",
    "trustedResources": "\u041d\u0430\u0434\u0451\u0436\u043d\u044b\u0435 \u0440\u0435\u0441\u0443\u0440\u0441\u044b"
  },
